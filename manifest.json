{
  "manifest_version": 3,
  "name": "BoardGPT",
  "description": "Ask GPT about your board questions",
  "version": "2",
  "author": "Maulin Shah, MD",

  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "host_permissions": ["https://api.openai.com/*"],
  "content_scripts": [
    {
      "matches": ["*://*.starttest.com/*"],
      "js": ["content.js"]
    }
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "permissions": ["tabs", "sidePanel", "storage", "clipboardWrite"],
  "action": {
    "default_title": "BoardGPT"
  },
  "background": {
    "service_worker": "service-worker.js"
  }
}
